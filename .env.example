# Copy this file to .env.local and fill in the values.

# MongoDB Atlas connection string (Atlas → Connect → Drivers).
MONGODB_URI=""

# Secret for signing login (JWT) tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# SMTP email (sends the password-reset OTP by email). Leave blank in
# development — the OTP is printed to the server terminal instead.
# Gmail example: host smtp.gmail.com, port 587, user your@gmail.com,
# pass = a Google "App Password" (Google Account → Security → App passwords).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Legal Care India <no-reply@legalcareindia.com>"

# Fast2SMS (sends the password-reset OTP by SMS to the registered phone).
# Get it from Fast2SMS dashboard → Dev API → API Key. Leave blank in
# development — the OTP is printed to the server terminal instead.
FAST2SMS_API_KEY=""

# ── SEO / Analytics (all optional — loaded only when set) ──────
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=""
# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=""
# Search-engine ownership verification tokens
GOOGLE_SITE_VERIFICATION=""
BING_SITE_VERIFICATION=""
